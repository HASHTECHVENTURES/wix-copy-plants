{
  "version": 2,
  "installCommand": "npm install --legacy-peer-deps && npm install --prefix backend",
  "buildCommand": "DISABLE_ESLINT_PLUGIN=true npm run build && rm -rf backend/build && cp -r build backend/build",
  "builds": [
    {
      "src": "backend/src/server.js",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "backend/src/server.js"
    },
    {
      "src": "/(.*)",
      "dest": "backend/src/server.js"
    }
  ]
}
