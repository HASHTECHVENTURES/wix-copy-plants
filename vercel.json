{
  "version": 2,
  "installCommand": "npm install && npm install --prefix backend",
  "buildCommand": "npm run build && rm -rf backend/build && cp -r build backend/build",
  "builds": [
    {
      "src": "backend/src/server.js",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "backend/src/server.js"
    }
  ]
}
